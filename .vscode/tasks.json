{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "cmake: configure",
            "type": "shell",
            "command": "cmake -S . -B build-local",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": []
        },
        {
            "label": "cmake: build peanutbutter",
            "type": "shell",
            "command": "cmake --build build-local --target peanutbutter",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "dependsOn": "cmake: configure",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "cmake: build peanutbutter_runner",
            "type": "shell",
            "command": "cmake --build build-local --target peanutbutter_runner",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "dependsOn": "cmake: configure",
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "cmake: configure release-max",
            "type": "shell",
            "command": "cmake -S . -B build-release -DCMAKE_BUILD_TYPE=Release",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": []
        },
        {
            "label": "cmake: build peanutbutter (release-max)",
            "type": "shell",
            "command": "cmake --build build-release --target peanutbutter",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "dependsOn": "cmake: configure release-max",
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "cmake: build peanutbutter_runner (release-max)",
            "type": "shell",
            "command": "cmake --build build-release --target peanutbutter_runner",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "dependsOn": "cmake: configure release-max",
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "type": "cppbuild",
            "label": "C/C++: clang build active file",
            "command": "/usr/bin/clang",
            "args": [
                "-fcolor-diagnostics",
                "-fansi-escape-codes",
                "-g",
                "${file}",
                "-o",
                "${fileDirname}/${fileBasenameNoExtension}"
            ],
            "options": {
                "cwd": "${fileDirname}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": "none",
            "detail": "Task generated by Debugger."
        }
    ]
}
